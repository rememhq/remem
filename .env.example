# ========================
# remem — Environment Variables
# ========================
# Copy to .env and fill in your values.
# NEVER commit .env to version control.

# --- LLM Provider API Keys ---
# At least one is required for reasoning operations.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GOOGLE_API_KEY=           # (v0.2+)

# --- Provider Selection ---
# Which provider to use for reasoning: "anthropic" or "openai"
REMEM_PROVIDER=anthropic

# --- REST API ---
# Bearer token for API authentication. If unset, API runs in open (dev) mode.
REMEM_API_KEY=

# --- Storage ---
# Override default data directory (~/.remem/projects)
# REMEM_DATA_DIR=

# --- Logging ---
# Set log level: trace, debug, info, warn, error
RUST_LOG=remem=info
